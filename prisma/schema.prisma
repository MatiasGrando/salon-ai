// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum ConversationStep {
  START
  ASK_SERVICE
  ASK_PROFESSIONAL
  ASK_DATE
  ASK_TIME
  ASK_CUSTOMER_NAME
  CONFIRM
  COMPLETED
  CANCEL_SELECT_APPOINTMENT
  EDIT_SELECT_APPOINTMENT
  HUMAN_HANDOFF
}

enum ConversationOpportunityStatus {
  OPEN
  CONVERTED
  CLOSED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum ScheduleBlockReason {
  ABSENCE
  VACATION
  LATE_ARRIVAL
  SICK_LEAVE
  PERSONAL
  TRAINING
  MAINTENANCE
  HOLIDAY
  OTHER
}

enum WhatsAppConnectionStatus {
  NOT_CONNECTED
  CONNECTING
  CONNECTED
  NEEDS_PAYMENT
  NEEDS_REVIEW
  ERROR
}

enum WhatsAppConnectionMode {
  CLIENT_OWNED
  INTERNAL_TEST
}

enum BillingOwner {
  CLIENT
  SALON_AI
}

enum UserRole {
  SUPER_ADMIN
  BUSINESS_ADMIN
  STAFF
}

model Business {
  id            String         @id @default(cuid())
  name          String
  slug          String?        @unique
  logoUrl       String?
  landingEnabled Boolean       @default(true)
  landingSubtitle String?
  landingOpeningYear Int?
  landingDescription String?
  coverImageUrl String?
  landingGalleryImages String?
  publicWhatsapp String?
  contactEmail String?
  publicAddress String?
  publicAddressArea String?
  publicMapsUrl String?
  instagramUrl String?
  facebookUrl String?
  botEnabled    Boolean        @default(true)
  aiEnabled     Boolean        @default(true)
  whatsappConfig BusinessWhatsAppConfig?
  featureSettings BusinessFeatureSettings?

  professionals Professional[]
  services      Service[]
  businessHours BusinessHours[]
  scheduleBlocks ScheduleBlock[]
  conversations Conversation[]
  campaigns     Campaign[]
  whatsappTemplates WhatsAppTemplate[]
  marketingPreferences CustomerMarketingPreference[]
  campaignDeliveries CampaignDelivery[]
  campaignRuns CampaignRun[]
  campaignJobs CampaignJob[]
  reminderAutomations ReminderAutomation[]
  reminderDeliveries ReminderDelivery[]
  postSaleAutomation PostSaleAutomation?
  postSaleDeliveries PostSaleDelivery[]
  communicationExecutions CommunicationExecution[]
  communicationRecipients CommunicationRecipient[]
  users User[]
  weexCustomerLinks WeexCustomerLink[]

  createdAt     DateTime       @default(now())
}

model User {
  id String @id @default(cuid())

  email String @unique
  name String
  passwordHash String
  role UserRole @default(BUSINESS_ADMIN)
  isActive Boolean @default(true)

  businessId String?
  business Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)
  professionalId String?
  professional Professional? @relation(fields: [professionalId], references: [id], onDelete: SetNull)
  sessions UserSession[]
  canCreateAppointments Boolean @default(true)
  canEditAppointments Boolean @default(true)
  canCancelAppointments Boolean @default(true)
  canManageScheduleBlocks Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([professionalId])
  @@index([role])
}

model UserSession {
  id String @id @default(cuid())

  tokenHash String @unique
  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model BusinessWhatsAppConfig {
  id String @id @default(cuid())

  businessId String @unique
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  connectionStatus WhatsAppConnectionStatus @default(NOT_CONNECTED)
  mode WhatsAppConnectionMode @default(CLIENT_OWNED)
  wabaId String?
  phoneNumberId String?
  displayPhoneNumber String?
  metaAppId String?
  accessToken String?
  tokenExpiresAt DateTime?
  connectedAt DateTime?
  disconnectedAt DateTime?
  lastError String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BusinessFeatureSettings {
  id String @id @default(cuid())

  businessId String @unique
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  botEnabled Boolean @default(true)
  aiEnabled Boolean @default(true)
  campaignsEnabled Boolean @default(false)
  remindersEnabled Boolean @default(false)
  realWhatsappEnabled Boolean @default(false)
  bookingV2Enabled Boolean @default(false)
  billingOwner BillingOwner @default(CLIENT)
  campaignSendingLocked Boolean @default(true)
  reminderSendingLocked Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Professional {
  id         String   @id @default(cuid())
  name       String
  description String?
  avatarUrl  String?
  isActive   Boolean  @default(true)
  deactivatedAt DateTime?

  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  appointments Appointment[]
  workingHours ProfessionalHours[]
  scheduleBlocks ScheduleBlock[]
  serviceLinks ProfessionalService[]
  users User[]

  createdAt  DateTime @default(now())
}

model Service {
  id         String   @id @default(cuid())

  name       String
  duration   Int
  category   String?
  price      Int?
  imageUrl   String?

  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  appointments Appointment[]
  aliases      ServiceAlias[]
  professionalLinks ProfessionalService[]

  createdAt  DateTime @default(now())
}

model ProfessionalService {
  id String @id @default(cuid())

  professionalId String
  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  serviceId String
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([professionalId, serviceId])
  @@index([serviceId])
}

model ServiceAlias {
  id   String @id @default(cuid())
  name String

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id])
}

model Customer {
  id        String   @id @default(cuid())

  name      String
  phone     String

  appointments Appointment[]
  notes        CustomerNote[]
  marketingPreferences CustomerMarketingPreference[]
  campaignDeliveries CampaignDelivery[]
  manualCampaignRecipients CampaignManualRecipient[]
  campaignJobs CampaignJob[]
  reminderDeliveries ReminderDelivery[]
  postSaleDeliveries PostSaleDelivery[]
  communicationRecipients CommunicationRecipient[]
  weexLinks    WeexCustomerLink[]

  createdAt DateTime @default(now())
}

model WeexAccount {
  id String @id @default(cuid())

  googleSub String @unique
  email String
  emailVerified Boolean @default(false)
  name String
  avatarUrl String?
  phone String?
  phoneVerifiedAt DateTime?
  googleCalendarAccessToken String?
  googleCalendarRefreshToken String?
  googleCalendarTokenExpiresAt DateTime?
  googleCalendarScope String?

  sessions WeexAccountSession[]
  customerLinks WeexCustomerLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([phone])
}

model WeexAccountSession {
  id String @id @default(cuid())

  tokenHash String @unique
  accountId String
  account WeexAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  expiresAt DateTime

  createdAt DateTime @default(now())

  @@index([accountId])
  @@index([expiresAt])
}

model WeexCustomerLink {
  id String @id @default(cuid())

  weexAccountId String
  weexAccount WeexAccount @relation(fields: [weexAccountId], references: [id], onDelete: Cascade)

  customerId String
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  businessId String
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  phone String
  linkedAt DateTime @default(now())

  @@unique([weexAccountId, customerId, businessId])
  @@index([weexAccountId, businessId])
  @@index([customerId])
  @@index([businessId])
  @@index([phone])
}

model CustomerNote {
  id         String   @id @default(cuid())
  body       String
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([customerId, createdAt])
}

model Appointment {
  id String @id @default(cuid())

  customerId String
  customer Customer @relation(fields: [customerId], references: [id])

  professionalId String
  professional Professional @relation(fields: [professionalId], references: [id])

  serviceId String
  service Service @relation(fields: [serviceId], references: [id])

  startAt DateTime

  status AppointmentStatus @default(CONFIRMED)
  reminderDeliveries ReminderDelivery[]
  convertedConversation Conversation? @relation("ConversationOpportunityAppointment")
  postSaleDeliveries PostSaleDelivery[]
  googleCalendarEventId String?
  googleCalendarAccountId String?

  createdAt DateTime @default(now())
}

model BusinessHours {
  id         String @id @default(cuid())

  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  dayOfWeek Int

  startTime String
  endTime   String
}

model ProfessionalHours {
  id String @id @default(cuid())

  professionalId String
  professional Professional @relation(fields: [professionalId], references: [id])

  dayOfWeek Int

  startTime String
  endTime String

  createdAt DateTime @default(now())
}

model Conversation {
  id String @id @default(cuid())

  phone String @unique
  businessId String?
  business Business? @relation(fields: [businessId], references: [id])

  currentStep ConversationStep @default(START)
  aiEnabled Boolean @default(true)
  misunderstandingCount Int @default(0)

  selectedServiceId String?
  selectedProfessionalId String?
  selectedDate String?
  selectedTime String?
  selectedCustomerName String?
  lastAvailability Json?
  bookingV2State Json?

  lastMessage String?
  humanHandoffAt DateTime?
  humanHandoffResolvedAt DateTime?
  archivedAt DateTime?

  opportunityStatus ConversationOpportunityStatus @default(OPEN)
  opportunityOpenedAt DateTime @default(now())
  opportunityConvertedAt DateTime?
  opportunityClosedAt DateTime?
  opportunityCloseReason String?
  opportunityCloseNote String?
  opportunityAppointmentId String? @unique
  opportunityAppointment Appointment? @relation("ConversationOpportunityAppointment", fields: [opportunityAppointmentId], references: [id], onDelete: SetNull)

  messages Message[]
  opportunityEvents ConversationOpportunityEvent[]
  postSaleDeliveries PostSaleDelivery[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId, archivedAt, updatedAt])
  @@index([currentStep, archivedAt, updatedAt])
  @@index([businessId, opportunityStatus, updatedAt])
}

model ConversationOpportunityEvent {
  id String @id @default(cuid())

  conversationId String
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  type String
  reason String?
  note String?
  appointmentId String?
  actorUserId String?
  createdAt DateTime @default(now())

  @@index([conversationId, createdAt])
}

model Message {
  id String @id @default(cuid())

  conversationId String
  conversation Conversation @relation(fields: [conversationId], references: [id])

  phone String
  direction MessageDirection
  body String

  providerMessageId String? @unique
  status String?
  providerStatusCode Int?
  providerErrorCode String?
  providerErrorMessage String?
  metadata Json?

  createdAt DateTime @default(now())
}

model ScheduleBlock {
  id String @id @default(cuid())

  businessId String
  business Business @relation(fields: [businessId], references: [id])

  professionalId String?
  professional Professional? @relation(fields: [professionalId], references: [id])

  reason ScheduleBlockReason
  title String?
  note String?

  startAt DateTime
  endAt DateTime

  createdAt DateTime @default(now())
}

model Campaign {
  id String @id @default(cuid())

  businessId String
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name String
  type String @default("ONE_TIME")
  channel String @default("WHATSAPP")
  status String @default("DRAFT")
  segment String @default("ALL")
  segmentLabel String @default("Todos los clientes")
  segmentDays Int?
  priority Int @default(2)
  maxAttempts Int @default(2)
  retryIntervalDays Int @default(30)
  cooldownDays Int @default(30)
  respectCooldown Boolean @default(true)
  stopOnBooking Boolean @default(true)
  stopOnReply Boolean @default(true)
  restartAfterVisit Boolean @default(true)
  message String
  imageUrl String?
  templateName String?
  templateLanguage String @default("es_AR")
  templateId String?
  templateStatus String @default("NOT_CREATED")
  templateRejectionReason String?
  templateLastSyncedAt DateTime?
  whatsappTemplateId String?
  whatsappTemplate WhatsAppTemplate? @relation(fields: [whatsappTemplateId], references: [id], onDelete: SetNull)
  scheduleMode String @default("IMMEDIATE")
  scheduledAt DateTime?
  budgetLimit Int?
  deliveries CampaignDelivery[]
  manualRecipients CampaignManualRecipient[]
  runs CampaignRun[]
  jobs CampaignJob[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId, status, updatedAt])
  @@index([whatsappTemplateId])
}

model WhatsAppTemplate {
  id String @id @default(cuid())

  businessId String
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  internalName String
  metaName String
  category String @default("MARKETING")
  language String @default("es_AR")
  body String
  exampleJson String?
  imageUrl String?
  status String @default("DRAFT")
  metaId String?
  rejectionReason String?
  submittedAt DateTime?
  lastSyncedAt DateTime?
  campaigns Campaign[]
  postSaleAutomations PostSaleAutomation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, metaName, language])
  @@index([businessId, status, updatedAt])
}

model ReminderAutomation {
  id String @id @default(cuid())

  businessId String
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name String
  channel String @default("WHATSAPP")
  templateId String?
  enabled Boolean @default(false)
  sendBeforeMinutes Int @default(1440)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deliveries ReminderDelivery[]

  @@index([businessId, enabled])
  @@index([businessId, sendBeforeMinutes])
}

model ReminderDelivery {
  id String @id @default(cuid())

  businessId String
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  reminderAutomationId String
  reminderAutomation ReminderAutomation @relation(fields: [reminderAutomationId], references: [id], onDelete: Cascade)

  appointmentId String
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  customerId String
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  status String @default("SENT")
  providerMessageId String?
  attemptNumber Int @default(1)
  lastError String?
  scheduledFor DateTime
  sentAt DateTime @default(now())
  deliveredAt DateTime?
  readAt DateTime?
  createdAt DateTime @default(now())

  @@unique([reminderAutomationId, appointmentId])
  @@index([businessId, status, sentAt])
  @@index([appointmentId])
  @@index([customerId, sentAt])
}

model PostSaleAutomation {
  id String @id @default(cuid())

  businessId String @unique
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  enabled Boolean @default(false)
  mode String @default("PAUSED")
  delayMinutes Int @default(120)
  responseWindowDays Int @default(7)
  lowRatingThreshold Int @default(2)
  templateId String?
  template WhatsAppTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  positiveResponse String @default("Gracias por tu calificación. Nos alegra que hayas tenido una buena experiencia.")
  neutralResponse String @default("Gracias por responder. Nos gustaría saber qué podríamos mejorar.")
  negativeResponse String @default("Lamentamos que tu experiencia no haya sido buena. El equipo va a contactarte por este chat.")
  reviewUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deliveries PostSaleDelivery[]

  @@index([enabled, businessId])
  @@index([mode, businessId])
  @@index([templateId])
}

model PostSaleDelivery {
  id String @id @default(cuid())

  businessId String
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  automationId String?
  automation PostSaleAutomation? @relation(fields: [automationId], references: [id], onDelete: SetNull)
  appointmentId String
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  customerId String
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  conversationId String?
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  visitDate String
  status String @default("PENDING")
  mode String @default("WHATSAPP_API")
  messageSnapshot String?
  providerMessageId String?
  lastError String?
  scheduledFor DateTime
  openedAt DateTime?
  sentAt DateTime?
  skippedAt DateTime?
  resolvedAt DateTime?
  manualNote String?
  responseExpiresAt DateTime?
  respondedAt DateTime?
  rating Int?
  comment String?
  commentRequestedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, customerId, visitDate])
  @@index([businessId, status, scheduledFor])
  @@index([conversationId, status, responseExpiresAt])
  @@index([appointmentId])
}

model CampaignManualRecipient {
  id String @id @default(cuid())

  campaignId String
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  customerId String
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([campaignId, customerId])
  @@index([customerId])
}

model CustomerMarketingPreference {
  id String @id @default(cuid())

  businessId String
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  customerId String
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  status String @default("NOT_AUTHORIZED")
  source String @default("DEFAULT")
  optedInAt DateTime?
  declinedAt DateTime?
  optedOutAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, customerId])
  @@index([businessId, status])
}

model CampaignDelivery {
  id String @id @default(cuid())

  businessId String
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  campaignId String
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  customerId String
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  status String @default("SENT")
  attemptNumber Int @default(1)
  providerMessageId String?
  sentAt DateTime @default(now())
  deliveredAt DateTime?
  readAt DateTime?
  respondedAt DateTime?
  bookedAt DateTime?
  createdAt DateTime @default(now())

  @@index([businessId, customerId, sentAt])
  @@index([campaignId, customerId, sentAt])
}

model CampaignRun {
  id String @id @default(cuid())

  businessId String
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  campaignId String
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  mode String @default("SIMULATION")
  status String @default("COMPLETED")
  candidateCount Int @default(0)
  eligibleCount Int @default(0)
  excludedCount Int @default(0)
  exclusionSummary Json
  configurationSnapshot Json
  createdAt DateTime @default(now())
  completedAt DateTime?

  jobs CampaignJob[]

  @@index([campaignId, createdAt])
  @@index([businessId, createdAt])
}

model CampaignJob {
  id String @id @default(cuid())

  businessId String
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  campaignId String
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  runId String
  run CampaignRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  customerId String
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  status String @default("READY")
  attemptNumber Int @default(1)
  retryCount Int @default(0)
  maxRetries Int @default(3)
  nextAttemptAt DateTime @default(now())
  lockedAt DateTime?
  lockToken String?
  idempotencyKey String @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([runId, customerId])
  @@index([status, nextAttemptAt])
  @@index([campaignId, customerId])
  @@index([businessId, status])
}

model CommunicationExecution {
  id String @id @default(cuid())

  businessId String
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  sourceType String
  sourceId String
  purpose String
  mode String
  status String @default("READY")
  initiatedByUserId String?
  candidateCount Int @default(0)
  eligibleCount Int @default(0)
  excludedCount Int @default(0)
  metadata Json?
  startedAt DateTime @default(now())
  completedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recipients CommunicationRecipient[]

  @@index([businessId, sourceType, sourceId, createdAt])
  @@index([businessId, status, createdAt])
}

model CommunicationRecipient {
  id String @id @default(cuid())

  executionId String
  execution CommunicationExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  businessId String
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerId String
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  phoneSnapshot String
  customerNameSnapshot String
  messageSnapshot String
  status String @default("PENDING")
  sourceDeliveryId String? @unique
  providerMessageId String?
  scheduledAt DateTime?
  openedAt DateTime?
  sentAt DateTime?
  deliveredAt DateTime?
  readAt DateTime?
  respondedAt DateTime?
  bookedAt DateTime?
  skippedAt DateTime?
  failedAt DateTime?
  skipReason String?
  failureReason String?
  metadata Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events CommunicationEvent[]

  @@unique([executionId, customerId])
  @@index([businessId, customerId, sentAt])
  @@index([businessId, status, scheduledAt])
}

model CommunicationEvent {
  id String @id @default(cuid())

  recipientId String
  recipient CommunicationRecipient @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  fromStatus String?
  toStatus String
  actorType String @default("SYSTEM")
  actorId String?
  note String?
  createdAt DateTime @default(now())

  @@index([recipientId, createdAt])
}
